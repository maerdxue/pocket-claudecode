# 复制为 .env 后填入真实值：cp .env.example .env
# .env 已被 .gitignore 忽略，不会提交。飞书凭证获取见 docs/feishu-setup.md。

# 飞书自建应用凭证（open.feishu.cn → 开发者后台 → 你的应用 →「凭证与基础信息」）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 你的飞书 open_id，用于白名单（只接受你本人发来的消息）。
# 获取：先把上面两项填好并起 relay，给机器人发任意一条消息，
#       看 relay 日志里的 from=ou_xxx，复制 ou_... 填回这里。
# 留空 = 不校验发送者（任何能联系到机器人的飞书用户都能操控你的电脑，不建议留空）。
FEISHU_MY_OPEN_ID=

# relay 本地 push 端口（全局 Stop/Notification hook 往这里 POST 结果）。
# 默认 7788。改了要重跑 bin/install-hooks（hook 里也读这个端口）。
RELAY_PORT=7788

# 轮询扫描 CC 会话登记本（~/.claude/sessions）的间隔（秒）。默认 5。
POLL_SEC=5
