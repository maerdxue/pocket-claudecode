#!/usr/bin/env bash
# 监督 relay：崩了/卡了自动拉起（每 10s 探 /health）
# 用法：在 tmux 会话 relay 里跑 `bin/relay-watchdog`。可重复跑。
# 环境变量：NODE（指定 node 路径，默认 PATH 里的 node）、RELAY_PORT（默认 7788）。
set -euo pipefail

PROJ="$(cd "$(dirname "$0")/.." && pwd)"
NODE="${NODE:-$(command -v node || true)}"
RELAY="$PROJ/relay.js"
PORT="${RELAY_PORT:-7788}"

if [[ -z "$NODE" ]]; then
  echo "❌ 找不到 node，请先装 Node.js 20+，或用 NODE=/path/to/node 指定" >&2
  exit 1
fi

while true; do
  "$NODE" "$RELAY" &
  PID=$!
  echo "$(date '+%H:%M:%S') relay started pid=$PID"
  START=$(date +%s)
  FAIL=0
  while kill -0 $PID 2>/dev/null; do
    sleep 10
    if [ $(( $(date +%s) - START )) -lt 30 ]; then continue; fi  # 启动宽限 30s：只看进程崩没，不探 health（避免启动窗口误杀）
    if ! curl -sf "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1; then
      FAIL=$((FAIL + 1))
      echo "$(date '+%H:%M:%S') health 失败 ($FAIL/3)"
      if [ "$FAIL" -ge 3 ]; then
        echo "$(date '+%H:%M:%S') 连续 3 次失败，kill 重启"
        kill $PID 2>/dev/null; break
      fi
    else
      FAIL=0
    fi
  done
  echo "$(date '+%H:%M:%S') relay 退出，2s 后重启"
  sleep 2
done
